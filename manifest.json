{
  "manifest_version": 3,
  "name": "Chrome Raindrop Sync",
  "version": "1.2.1",
  "description": "自动同步 Chrome 书签与 Raindrop.io",
  "permissions": [
    "alarms",
    "bookmarks",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://api.raindrop.io/*",
    "https://raindrop.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
